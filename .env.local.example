# Anthropic — used for the written skin analysis (Claude vision)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used for the before/after image (gpt-image-2 edits endpoint)
OPENAI_API_KEY=sk-...

# GoHighLevel inbound webhook URL (Workflows -> Inbound Webhook trigger)
# Leads are POSTed here as JSON before results are revealed.
GHL_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...

# GoHighLevel Private Integration — uploads the branded PDF report, attaches it
# to the contact (custom field + note) and emails the client a copy via
# /api/report. Both token + location are required to enable delivery; if unset,
# the report step is skipped silently and the flow still completes.
GHL_API_TOKEN=pit-...
GHL_LOCATION_ID=...
# Bare GHL custom-field key (no "contact." prefix) the report URL is written into.
GHL_REPORT_FIELD_KEY=facial_app_report_pdf

# Where the "Book a consultation" button (and the report email link) send users —
# the consultation booking widget.
NEXT_PUBLIC_BOOKING_URL=https://link.harleystreetaesthetic.co.uk/widget/bookings/aesthetic-consultant-1

# General clinic website — used for brand links (e.g. the report email signature).
NEXT_PUBLIC_SITE_URL=https://harleystreetaesthetic.co.uk/

# Meta (Facebook) Pixel ID — used for PageView + Lead events and the
# Conversions API fields forwarded to GHL. Demo: leave unset/replace with the
# Harley Street pixel before any real campaign.
NEXT_PUBLIC_META_PIXEL_ID=
